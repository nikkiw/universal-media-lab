COMPOSE_PROJECT_NAME=media-lab
GATEWAY_PORT=8080
TOXIPROXY_API_PORT=8474
NETWORK_DYNAMIC_PORT=18080
NETWORK_CLEAN_PORT=18081
NETWORK_WIFI_PORT=18082
NETWORK_LTE_PORT=18083
NETWORK_SLOW_LTE_PORT=18084
NETWORK_3G_PORT=18085
NETWORK_EDGE_PORT=18086
NETWORK_FLAKY_PORT=18087
NETWORK_OFFLINE_PORT=18088
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
IMGPROXY_WORKERS=4
IMGPROXY_MAX_SRC_RESOLUTION=100
IMGPROXY_MAX_ANIMATION_FRAMES=500

# Pinned defaults as of 2026-07-12. Override here when deliberately upgrading.
NGINX_VERSION=1.28-alpine
IMGPROXY_VERSION=v4.0.11
WIREMOCK_VERSION=3.13.2
TOXIPROXY_VERSION=2.12.0
PROMETHEUS_VERSION=v3.13.1
GRAFANA_VERSION=13.1.0
CURL_VERSION=8.12.1

# Media ingest defaults.
MEDIA_SEGMENT_SECONDS=2
MEDIA_FRAME_RATE=30
MEDIA_POSTER_SECOND=1
MEDIA_STORYBOARD_INTERVAL=5
MEDIA_FFMPEG_PRESET=veryfast

# Tool images used only by `make ingest`.
FFMPEG_VERSION=8.1-alpine320
PYTHON_VERSION=3.13.14-alpine3.24
