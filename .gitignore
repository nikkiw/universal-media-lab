# Local environment variables
.env

# macOS system files
.DS_Store

# Docker temporary files and mounted volumes
*.log
.docker/

# IDE folders
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Temporary test mappings
/wiremock/mappings/*-tmp.json

# Local source videos and generated media assets
/media/inbox/*
!/media/inbox/.gitkeep
/media/generated/*
!/media/generated/.gitkeep
/media/catalog/
/media/.work/

# Python bytecode
__pycache__/
*.py[cod]
